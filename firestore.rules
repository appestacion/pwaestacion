// Reglas PERMISIVAS de emergencia para CIERREESMF
// Solo requiere estar autenticado. Sin restricciones de isActive ni isAdmin.
// TODO: Tighten security cuando la app esté estable.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    // ==========================================
    // COLECCIÓN: users
    // ==========================================
    match /users/{userId} {
      allow read, write: if isAuthenticated();
    }

    // ==========================================
    // COLECCIÓN: shifts (turnos)
    // ==========================================
    match /shifts/{shiftId} {
      allow read, write: if isAuthenticated();
    }

    // ==========================================
    // COLECCIÓN: gandolaReceptions
    // ==========================================
    match /gandolaReceptions/{receptionId} {
      allow read, write: if isAuthenticated();
    }

    // ==========================================
    // COLECCIÓN: products (productos)
    // ==========================================
    match /products/{productId} {
      allow read, write: if isAuthenticated();
    }

    // ==========================================
    // COLECCIÓN: settings (configuracion)
    // ==========================================
    match /settings/{settingId} {
      allow read, write: if isAuthenticated();
    }

    // ==========================================
    // COLECCIÓN: inventory (inventario)
    // ==========================================
    match /inventory/{itemName} {
      allow read, write: if isAuthenticated();
    }

    // ==========================================
    // COLECCIÓN: islandInventory (inventario por isla)
    // ESTA COLECCIÓN FALTABA EN TUS REGLAS ANTERIORES
    // ==========================================
    match /islandInventory/{itemId} {
      allow read, write: if isAuthenticated();
    }

    // ==========================================
    // CATCH-ALL: DENEGAR TODO LO DEMÁS
    // ==========================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}